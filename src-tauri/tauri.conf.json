{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex 用量悬浮球",
  "version": "0.1.1",
  "identifier": "im.fjh.codexusageball",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "ball",
        "title": "Codex 用量悬浮球",
        "url": "index.html?window=ball",
        "width": 112,
        "height": 140,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "center": true,
        "skipTaskbar": true
      },
      {
        "label": "main",
        "title": "Codex 用量",
        "url": "index.html?window=main",
        "width": 356,
        "height": 580,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "center": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "设置",
        "url": "index.html?window=settings",
        "width": 380,
        "height": 430,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
